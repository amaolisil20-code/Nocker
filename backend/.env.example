# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# JWT Configuration
# OBRIGATÓRIO em produção: gere um valor aleatório forte, por exemplo com
# `python -c "import secrets; print(secrets.token_hex(32))"`.
JWT_SECRET=your-secret-key-change-me

# CORS - opcional. Lista de origens permitidas separadas por vírgula.
# Deixe vazio/"*" para permitir qualquer origem (ok para app mobile).
CORS_ORIGINS=

# LLM Configuration
EMERGENT_LLM_KEY=your-emergent-llm-key
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OCR_SPACE_API_KEY=

# Open Finance / Pluggy
OPEN_FINANCE_PROVIDER=mock
OPEN_FINANCE_SYNC_ON_OPEN=true
# Para modo real, use: OPEN_FINANCE_PROVIDER=pluggy
PLUGGY_BASE_URL=https://api.pluggy.ai
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
# OBRIGATÓRIO em produção: gere um valor aleatório forte (mesmo comando do
# JWT_SECRET acima). É usada para criptografar os tokens bancários salvos.
# Se já existirem conexões reais criptografadas com uma chave antiga, NÃO
# troque este valor direto em produção: configure OF_TOKEN_KEY_LEGACY com o
# valor antigo, rode scripts/rotate_of_token_key.py para migrar os registros,
# e só depois remova OF_TOKEN_KEY_LEGACY.
OF_TOKEN_KEY=change-me-open-finance-token-key
# Opcional: chave(s) antiga(s) do OF_TOKEN_KEY, separadas por vírgula, usadas
# só como fallback de leitura durante uma rotação de chave (ver acima).
OF_TOKEN_KEY_LEGACY=
