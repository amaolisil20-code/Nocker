EXPO_PUBLIC_BACKEND_URL=https://nocker-backend.onrender.com
EXPO_PUBLIC_OPEN_FINANCE_ALLOW_FALLBACK=true
# false em produção real (com credenciais Pluggy certificadas) — só use true
# se o backend ainda estiver rodando com credenciais SANDBOX do Pluggy.
EXPO_PUBLIC_OPEN_FINANCE_SANDBOX=false

# Necessárias para o login com Google (Supabase Auth) em app/login.tsx.
# Pegue esses valores em Supabase > Project Settings > API.
EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
